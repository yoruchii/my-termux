#!/bin/bash                                                                                                       # ===== FUNGSI HEX -> ANSI =====
hex_to_ansi() {                                              local hex="${1#"#"}"
    local r=$((16#${hex:0:2}))
    local g=$((16#${hex:2:2}))
    local b=$((16#${hex:4:2}))
    printf "\033[38;2;%d;%d;%dm" "$r" "$g" "$b"
}                                                        
# ===== RESET WARNA =====
RESET="\033[0m"                                          
# ===== VARIABEL WARNA =====
RED=$(hex_to_ansi "#fb4934")
GREEN=$(hex_to_ansi "#98971a")
YELLOW=$(hex_to_ansi "#fabd2f")
                                                         # ===== ASCII ART =====                                  printf "                                                 в•­в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•®
в”‚ ${GREEN}Yoru Chii${RESET}                    ${GREEN}п„‘${RESET} ${YELLOW}п„‘${RESET} ${RED}п„‘${RESET} в”‚
"
cat << "EOF"
в”‚           /`-._                    в”‚
в”‚         _/,.._/                    в”‚
в”‚      ,-'   ,  `-:,.-')    _        в”‚
в”‚     : o ):';     _  {    (_)       в”‚
в”‚      `-.  `' _,.-\`-.)    +        в”‚
в”‚         `\\``\,.-'                 в”‚
в”‚                                    в”‚
EOF
